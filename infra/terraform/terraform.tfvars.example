# Copy to terraform.tfvars and fill in. Do NOT commit real values.
# Sensitive values (passwords) are better supplied via TF_VAR_* env vars or OCI Vault.

tenancy_ocid     = "ocid1.tenancy.oc1..xxxx"
compartment_ocid = "ocid1.compartment.oc1..xxxx"
region           = "ap-mumbai-1"
environment      = "dev"

atp_db_name        = "krishimitradb"
atp_is_free_tier   = true
# atp_admin_password is intentionally omitted; set via:
#   PowerShell:  $env:TF_VAR_atp_admin_password = '...'
#   bash:        export TF_VAR_atp_admin_password='...'

# --- FREE PATH (default): everything below stays within Always Free ---
enable_paid_services = false          # true = add paid API Gateway + Streaming
compute_shape        = "VM.Standard.A1.Flex"
compute_ocpus        = 1
compute_memory_gbs   = 6
# compute_image_ocid = "ocid1.image.oc1..<oracle-linux-8-aarch64>"  # region-specific
# ssh_public_key     = "ssh-rsa AAAA..."   # better: set TF_VAR_ssh_public_key
lb_min_bandwidth_mbps = 10              # 10 Mbps keeps the LB Always Free
lb_max_bandwidth_mbps = 10
