PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ─── Database ────────────────────────────────────────────────────────────────
# Supabase Session Pooler URL (Project Settings → Database → Connection string
# → Session mode). URL-encode special chars in the password (/ → %2F, % → %25).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DB_POOL_MAX=5
DB_SSL=true

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project Settings → API
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE=sb_secret_...
SUPABASE_DISEASE_BUCKET=disease-scans

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Set AUTH_DISABLED=true for development/demo only.
AUTH_DISABLED=true
# JWT_SECRET=your-secret-here          # for HS256
# JWT_JWKS_URI=https://.../.well-known/jwks.json  # for RS256 (Supabase Auth)

# ─── Cron jobs ────────────────────────────────────────────────────────────────
ENABLE_JOBS=true

# ─── Data sources ─────────────────────────────────────────────────────────────
# Open-Meteo weather is keyless — no config needed.
# Get a free key at https://data.gov.in (profile → API key).
DATAGOV_API_KEY=
AGMARKNET_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070

# ─── SMTP email alerts ────────────────────────────────────────────────────────
# Gmail: create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_SENDER=KrishiMitra <you@gmail.com>

# ─── ML artifacts ────────────────────────────────────────────────────────────
# Default: backend/ml-artifacts/ (committed to repo without the .onnx model).
# Download the model: see SUPABASE-SETUP.md § Disease AI.
ML_ARTIFACTS_DIR=ml-artifacts
DISEASE_MODEL_FILE=disease_mobilenetv3.onnx
DISEASE_LABELS_FILE=class_labels.json
DISEASE_LOOKUP_FILE=disease_lookup.json
